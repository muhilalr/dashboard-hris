NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_DEBUG=false
ENABLE_DEV_ROLE_LOGIN=true

# Untuk Google OAuth, daftarkan callback URI ini di Google Cloud Console:
# Local:      http://localhost:3000/api/auth/callback/google
# Production: https://your-domain.com/api/auth/callback/google

ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_odoo_database

# Dipakai untuk login email/username + password
# Tidak perlu diisi user biasa, hanya untuk koneksi aplikasi ke Odoo saat Google SSO.
ODOO_SERVICE_LOGIN=service-account@your-company.com
ODOO_SERVICE_PASSWORD=service-account-password

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Override role bila ingin memaksa berdasarkan email.
HRIS_HEAD_EMAILS=head1@gmail.com,head2@gmail.com
HRIS_MANAGER_EMAILS=manager1@gmail.com,founder@gmail.com
